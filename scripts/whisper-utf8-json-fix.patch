+static int utf8_expected_len(unsigned char c) {
+    if ((c & 0x80) == 0)    return 1;
+    if ((c & 0xE0) == 0xC0) return 2;
+    if ((c & 0xF0) == 0xE0) return 3;
+    if ((c & 0xF8) == 0xF0) return 4;
+    return 1;
+}
+
+// returns the length of the longest prefix of s that ends on a complete
+// utf-8 character boundary. any trailing incomplete multi-byte sequence
+// is excluded so it can be carried over to the next token.
+static size_t utf8_valid_prefix_length(const std::string & s) {
+    if (s.empty()) return 0;
+
+    size_t len = s.size();
+
+    size_t i = len;
+    while (i > 0 && (static_cast<unsigned char>(s[i - 1]) & 0xC0) == 0x80) {
+        --i;
+    }
+
+    if (i == 0) return 0;
+
+    size_t lead_pos = i - 1;
+    int expected = utf8_expected_len(static_cast<unsigned char>(s[lead_pos]));
+    int actual = static_cast<int>(len - lead_pos);
+
+    if (actual >= expected) {
+        return len;
+    }
+
+    return lead_pos;
+}
