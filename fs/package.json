{
  "name": "@storyteller-platform/fs",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/storyteller-platform/storyteller"
  },
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "yarn build"
  },
  "devDependencies": {
    "@storyteller-platform/eslint": "workspace:*",
    "@storyteller-platform/tsup": "workspace:^",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^24.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.5.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  }
}
