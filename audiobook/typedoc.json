{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "entryPoints": [
    "./src/index.ts",
    "./src/base.ts",
    "./src/entry.ts",
    "./src/node/index.ts",
    "./src/node/entry.ts"
  ],
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-remark"],
  "readme": "none",
  "mergeReadme": false,
  "gitRevision": "main",
  "router": "module",
  "out": "./gen",
  "entryModule": "./src/node/index.ts",
  "cleanOutputDir": true,
  "hidePageHeader": true,
  "hideGroupHeadings": true,
  "formatWithPrettier": true,
  "parametersFormat": "table",
  "remarkPlugins": [["remark-toc", { "maxDepth": 4, "heading": "API Docs" }]],
  "defaultRemarkPlugins": {
    "gfm": true,
    "frontmatter": false,
    "mdx": false
  }
}
