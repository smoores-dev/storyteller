{
  "name": "@smoores/audiobook",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "@storyteller": "./src/index.ts",
      "@storyteller-node": "./src/node/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node": {
      "@storyteller": "./src/node/index.ts",
      "@storyteller-node": "./src/node/index.ts",
      "import": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.js"
      },
      "require": {
        "types": "./dist/node/index.d.cts",
        "default": "./dist/node/index.cjs"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "readme:toc": "markdown-toc --maxdepth=5 --append='\n- [API Docs](#api-docs)' --bullets='-' -i readme-stub.md",
    "readme:api": "typedoc",
    "readme": "yarn readme:api && yarn readme:toc && cat readme-stub.md > README.md && tail -n +2 gen/README.md >> README.md",
    "test": "rm -rf src/__fixtures__/__output__ && tsx -C @storyteller --test src/**/*.test.ts",
    "test:watch": "tsx --test --watch  -C @storyteller --test src/**/*.test.ts"
  },
  "devDependencies": {
    "@storyteller/tsup": "workspace:^",
    "@tsconfig/strictest": "^2.0.5",
    "@types/mime-types": "^2",
    "@types/node": "^22.10.1",
    "markdown-toc": "^1.2.0",
    "remark-toc": "^9.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.4",
    "typedoc-plugin-markdown": "^4.6.3",
    "typedoc-plugin-remark": "^1.2.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@einheit/path-resolve": "^1.2.0",
    "@smoores/fs": "workspace:^",
    "@smoores/path": "workspace:^",
    "@zip.js/zip.js": "^2.7.71",
    "async-mutex": "^0.5.0",
    "fast-xml-parser": "^4.0.0",
    "mem": "^8.0.0",
    "mime-types": "^3.0.1",
    "nanoid": "^5.1.5",
    "node-taglib-sharp": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
