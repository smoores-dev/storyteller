{
  "name": "@storyteller-platform/epub",
  "version": "0.2.1",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./node.ts",
      "browser": "./index.ts",
      "default": "./node.ts"
    },
    "./node": {
      "types": "./node.ts",
      "default": "./node.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "readme:toc": "markdown-toc --maxdepth=5 --append='\n- [API Docs](#api-docs)' --bullets='-' -i readme-stub.md",
    "readme:api": "typedoc",
    "readme": "yarn readme:api && yarn readme:toc && cat readme-stub.md > README.md && tail -n +2 gen/README.md >> README.md",
    "test": "tsx -C @storyteller --test index.test.ts",
    "test:watch": "tsx -C @storyteller --test --watch index.test.ts",
    "prepack": "yarn build"
  },
  "devDependencies": {
    "@storyteller-platform/tsup": "workspace:^",
    "@tsconfig/strictest": "^2.0.5",
    "@types/mime-types": "^2",
    "@types/node": "^24.0.0",
    "markdown-toc": "^1.2.0",
    "remark-toc": "^9.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.6.3",
    "typedoc-plugin-remark": "^1.2.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@storyteller-platform/fs": "workspace:^",
    "@storyteller-platform/path": "workspace:^",
    "@yarnpkg/fslib": "^3.1.3",
    "@yarnpkg/libzip": "^3.2.2",
    "@zip.js/zip.js": "^2.0.0",
    "async-mutex": "^0.5.0",
    "fast-xml-parser": "^4.0.0",
    "mem": "^8.0.0",
    "mime-types": "^3.0.1",
    "nanoid": "^5.1.5"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js",
        "browser": "./dist/index.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs",
        "browser": "./dist/index.cjs"
      }
    }
  }
}
