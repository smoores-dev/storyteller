+    // Grant URI permission for current track's artwork to automotive controllers
+    private fun grantArtworkUriPermissions() {
+        if (automotiveControllers.isEmpty()) return
+        if (!::player.isInitialized) return
+        val artworkUri = player.exoPlayer.currentMediaItem?.mediaMetadata?.artworkUri ?: return
+
+        // Only grant for content:// URIs
+        if (artworkUri.scheme != "content") return
+
+        Timber.d("Granting artwork URI permission: $artworkUri")
+        for (packageName in automotiveControllers) {
+            try {
+                grantUriPermission(
+                    packageName,
+                    artworkUri,
+                    Intent.FLAG_GRANT_READ_URI_PERMISSION
+                )
+                Timber.d("Granted URI permission to $packageName")
+            } catch (e: Exception) {
+                Timber.e(e, "Failed to grant URI permission to $packageName")
+            }
+        }
+    }
